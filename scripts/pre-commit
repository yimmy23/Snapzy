#!/bin/bash
# Get staged Swift files (ignoring deleted ones)
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

if [ -z "$STAGED_SWIFT_FILES" ]; then
  exit 0
fi

if which swiftformat >/dev/null; then
  echo "SwiftFormat pre-commit formatting is disabled (commented out)."
  # echo "Formatting staged Swift files..."
  # # Format each staged file
  # echo "$STAGED_SWIFT_FILES" | xargs swiftformat
  # # Re-stage formatted files
  # echo "$STAGED_SWIFT_FILES" | xargs git add
else
  echo "warning: SwiftFormat is not installed. Skipping pre-commit formatting."
fi
