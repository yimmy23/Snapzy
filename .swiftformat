# Format Options
--indent 4
--maxwidth 120
--linebreaks lf
--swiftversion 5.9
--semicolons never

# Rules to Disable
--disable wrapMultilineStatementBraces
--disable numberFormatting
--disable hoistPatternLet

# File exclusions
--exclude **/Pods
--exclude **/.build
--exclude **/build
--exclude **/DerivedData
--exclude **/Generated
